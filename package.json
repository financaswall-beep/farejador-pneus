{
  "name": "farejador",
  "version": "0.1.0",
  "private": true,
  "description": "Deterministic Chatwoot conversation capture into Supabase Postgres.",
  "license": "UNLICENSED",
  "type": "module",
  "engines": {
    "node": ">=20.10.0"
  },
  "scripts": {
    "dev": "tsx watch --env-file=.env src/app/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/app/server.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:all": "npm run test && npm run test:integration",
    "checar-tamanho": "node scripts/checar-tamanho.cjs",
    "prova-painel": "node scripts/prova-paridade-painel.cjs && node scripts/prova-endpoints-painel.cjs && node scripts/checar-tamanho.cjs",
    "enrich": "tsx --env-file=.env src/enrichment/cli.ts"
  },
  "dependencies": {
    "fastify": "^4.28.0",
    "pg": "^8.12.0",
    "pino": "^9.3.0",
    "sharp": "^0.34.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "^11.14.0",
    "@types/node": "^20.14.0",
    "@types/pg": "^8.11.0",
    "pino-pretty": "^11.2.0",
    "testcontainers": "^11.14.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "vitest": "^1.6.0"
  }
}

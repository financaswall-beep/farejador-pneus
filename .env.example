# Farejador - env vars
# Copy to `.env` (gitignored) and fill in real values. See docs/CONFIG.md.

# --- Runtime ---
NODE_ENV=development
FAREJADOR_ENV=prod
PORT=3000
# No Coolify: loopback, linklocal, uniquelocal. Local direto: false.
TRUST_PROXY=false
LOG_LEVEL=debug

# --- Database (Supabase Postgres) ---
DATABASE_URL=postgresql://postgres:password@host:6543/postgres
PARTNER_DATABASE_URL=postgresql://farejador_partner_app.project-ref:password@host:6543/postgres
# Fora do Coolify, defina o SHA explicitamente. O Coolify fornece SOURCE_COMMIT.
APP_COMMIT_SHA=unknown
DATABASE_POOL_MAX=10
DATABASE_SSL=false

# --- Chatwoot webhook ---
CHATWOOT_HMAC_SECRET=replace-with-real-secret
CHATWOOT_WEBHOOK_MAX_AGE_SECONDS=300

# --- Chatwoot API (used by admin reconcile) ---
CHATWOOT_API_BASE_URL=https://chatwoot.example.com/api/v1
CHATWOOT_API_TOKEN=replace-with-real-token
CHATWOOT_ACCOUNT_ID=1

# --- Admin auth ---
ADMIN_AUTH_TOKEN=generate-a-long-random-string
# A conta owner humana deve existir antes de usar este arquivo em producao.
ADMIN_BEARER_FALLBACK_ENABLED=false

# --- Normalization filter ---
# Comma-separated list of Chatwoot event types to mark as `skipped`.
# Raw events are still preserved.
SKIP_EVENT_TYPES=

# --- Deterministic analytics ---
SIGNAL_TIMEZONE=America/Sao_Paulo

# --- OpenAI (used by Agent V2) ---
OPENAI_API_KEY=sk-replace-with-real-key
OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT_MS=30000

# --- Agent V2 worker ---
# Polls ops.atendente_jobs and runs the unified function-calling agent.
AGENT_V2_WORKER_ENABLED=true
BOT_OUTBOX=false
AGENT_V2_POLL_INTERVAL_MS=5000
# Comma-separated conversation_ids that should be handled by V2. Use "*" for all.
AGENT_V2_CONVERSATION_IDS=*

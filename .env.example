# Farejador - env vars
# Copy to `.env` (gitignored) and fill in real values. See docs/CONFIG.md.

# --- Runtime ---
NODE_ENV=development
FAREJADOR_ENV=prod
PORT=3000
LOG_LEVEL=debug

# --- Database (Supabase Postgres) ---
DATABASE_URL=postgresql://postgres:password@host:6543/postgres
DATABASE_POOL_MAX=10
DATABASE_SSL=false

# --- Chatwoot webhook ---
CHATWOOT_HMAC_SECRET=replace-with-real-secret
CHATWOOT_WEBHOOK_MAX_AGE_SECONDS=300

# --- Chatwoot API (used by admin reconcile) ---
CHATWOOT_API_BASE_URL=https://chatwoot.example.com/api/v1
CHATWOOT_API_TOKEN=replace-with-real-token
CHATWOOT_ACCOUNT_ID=1

# --- Admin auth ---
ADMIN_AUTH_TOKEN=generate-a-long-random-string

# --- Normalization filter ---
# Comma-separated list of Chatwoot event types to mark as `skipped`.
# Raw events are still preserved.
SKIP_EVENT_TYPES=

# --- Deterministic analytics ---
SIGNAL_TIMEZONE=America/Sao_Paulo

# --- Organizadora (Fase 3) ---
# Requires migrations 0013-0026 in staging/prod.
ORGANIZADORA_ENABLED=false
OPENAI_API_KEY=sk-replace-with-real-key
OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT_MS=30000
ORGANIZADORA_DEBOUNCE_SECONDS=90
ORGANIZADORA_POLL_INTERVAL_MS=5000

# --- Atendente Planner / Shadow Worker / Generator ---
# Shadow is log-only: no Chatwoot send.
PLANNER_LLM_ENABLED=false
PLANNER_OPENAI_API_KEY=sk-replace-with-planner-key
PLANNER_MODEL=gpt-4o-mini
ATENDENTE_SHADOW_ENABLED=false
ATENDENTE_SHADOW_POLL_INTERVAL_MS=5000
ATENDENTE_CONTEXT_MESSAGES_LIMIT=20
GENERATOR_LLM_ENABLED=false
GENERATOR_OPENAI_API_KEY=sk-replace-with-generator-key
GENERATOR_MODEL=gpt-4o-mini
